# Caddyfile for PMS Ecosystem
# Automatic HTTPS with on-demand TLS for custom domains (future SaaS)

# Production configuration (uncomment when deploying)
# {
#   email admin@yourdomain.com
#   acme_ca https://acme-v02.api.letsencrypt.org/directory
# }

# Development configuration (HTTP only)
{
  local_certs
}

# API endpoint
:80 {
    # Health check endpoint (no auth required)
    handle /health {
        reverse_proxy api:3000
    }

    # API v1 routes
    handle /api/v1/* {
        reverse_proxy api:3000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # Default: redirect to API docs or return 404
    handle {
        respond "Not Found" 404
    }

    # Logging
    log {
        output stdout
        format json
    }
}

