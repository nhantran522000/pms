# ===========================================
# PMS Ecosystem - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# All variables are validated at startup via Zod schema

# ===========================================
# Application
# ===========================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# ===========================================
# Database (PostgreSQL 17)
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?options
DATABASE_URL=postgresql://pms:pms_password@localhost:5432/pms?connection_limit=10&pool_timeout=30

# ===========================================
# Authentication
# ===========================================
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session duration: 7 days (per CONTEXT.md decision)
JWT_EXPIRES_IN=7d

# Password reset token expiry: 1 hour (per CONTEXT.md decision)
PASSWORD_RESET_EXPIRY=3600

# ===========================================
# Email (Resend)
# ===========================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender email address
EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# Multi-tenancy
# ===========================================
# Default tenant for single-tenant setup
DEFAULT_TENANT_ID=default

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# Rate Limiting
# ===========================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ===========================================
# Future: AI Gateway (Phase 2)
# ===========================================
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Future: SaaS (Phase 8)
# ===========================================
# LEMONSQUEEZY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# LEMONSQUEEZY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Future: Cloudflare (Phase 12)
# ===========================================
# CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
