generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// HealthLogType - Types of health metrics tracked
enum HealthLogType {
  WEIGHT
  BLOOD_PRESSURE
  HEART_RATE
  SLEEP
  STEPS
  WORKOUT
  NUTRITION
  MOOD
  CUSTOM
}

/// HobbyTrackingType - Types of hobby progress tracking
enum HobbyTrackingType {
  COUNTER
  PERCENTAGE
  LIST
}

/// Tenant - Root entity for multi-tenancy
model Tenant {
  id                         String             @id @default(cuid())
  name                       String
  subscriptionTier           String             @default("FREE") @map("subscriptionTier")
  trialEndDate               DateTime?          @map("trialEndDate")
  branding                   Json? // TenantBranding: { primaryColor, appName, logoUrl }
  lemonsqueezyCustomerId     String?            @map("lemonsqueezyCustomerId")
  lemonsqueezySubscriptionId String?            @map("lemonsqueezySubscriptionId")
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  users                      User[]
  aiProviderConfigs          AiProviderConfig[]
  aiPromptCache              AiPromptCache[]
  aiUsageLogs                AiUsageLog[]
  categories                 Category[]
  accounts                   Account[]
  transactions               Transaction[]
  budgetEnvelopes            BudgetEnvelope[]
  recurringRules             RecurringRule[]
  tasks                      Task[]
  habits                     Habit[]
  habitCompletions           HabitCompletion[]
  userStats                  UserStats?
  achievements               Achievement[]
  healthLogs                 HealthLog[]
  folders                    Folder[]
  tags                       Tag[]
  notes                      Note[]
  journalEntries             JournalEntry[]
  hobbies                    Hobby[]
  hobbyLogs                  HobbyLog[]

  @@index([name])
  @@index([subscriptionTier])
  @@map("tenants")
}

/// User - Authentication and profile
model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  passwordHash              String    @map("passwordHash")
  name                      String?
  emailVerified             Boolean   @default(false) @map("emailVerified")
  verificationToken         String?   @map("verificationToken")
  verificationTokenExpires  DateTime? @map("verificationTokenExpires")
  passwordResetToken        String?   @map("passwordResetToken")
  passwordResetTokenExpires DateTime? @map("passwordResetTokenExpires")
  tenantId                  String    @map("tenantId")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  tenant                    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tenantId])
  @@index([verificationToken])
  @@index([passwordResetToken])
  @@map("users")
}

/// AiProviderConfig - AI provider configuration per tenant
model AiProviderConfig {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenantId")
  provider  String // "groq" or "gemini"
  modelName String   @map("modelName")
  isEnabled Boolean  @default(true) @map("isEnabled")
  priority  Int      @default(0) // 0 = highest priority
  config    Json? // provider-specific config (API key references, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([provider])
  @@map("ai_provider_configs")
}

/// AiPromptCache - Cache AI responses for 24h
model AiPromptCache {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenantId")
  promptHash String   @map("promptHash") // SHA-256 of normalized prompt
  taskType   String   @map("taskType") // CLASSIFY, LABEL, etc.
  response   Json // cached response
  tokensUsed Int      @map("tokensUsed")
  createdAt  DateTime @default(now())
  expiresAt  DateTime @map("expiresAt") // createdAt + 24h
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, promptHash])
  @@index([expiresAt])
  @@map("ai_prompt_cache")
}

/// AiUsageLog - Track AI usage for analytics and budgeting
model AiUsageLog {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenantId")
  provider     String
  model        String
  taskType     String   @map("taskType")
  inputTokens  Int      @map("inputTokens")
  outputTokens Int      @map("outputTokens")
  latencyMs    Int      @map("latencyMs")
  success      Boolean
  errorMessage String?  @map("errorMessage")
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([provider, createdAt])
  @@map("ai_usage_logs")
}

/// Category - Hierarchical categories for transactions
model Category {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenantId")
  name            String
  parentId        String?          @map("parentId")
  parent          Category?        @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[]       @relation("CategoryHierarchy")
  icon            String?
  color           String?
  type            String // "income" or "expense"
  isSystem        Boolean          @default(false) @map("isSystem")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  budgetEnvelopes BudgetEnvelope[]
  recurringRules  RecurringRule[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

/// Account - Financial accounts (checking, savings, cash, credit)
model Account {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenantId")
  name            String
  type            String // "checking", "savings", "cash", "credit"
  initialBalance  Decimal          @default(0) @map("initialBalance") @db.Decimal(15, 2)
  currentBalance  Decimal          @default(0) @map("currentBalance") @db.Decimal(15, 2)
  icon            String?
  color           String?
  isArchived      Boolean          @default(false) @map("isArchived")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  budgetEnvelopes BudgetEnvelope[]
  recurringRules  RecurringRule[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("accounts")
}

/// Transaction - Financial transactions
model Transaction {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenantId")
  accountId       String         @map("accountId")
  categoryId      String?        @map("categoryId")
  amount          Decimal        @db.Decimal(15, 2)
  type            String // "income" or "expense"
  payee           String?
  description     String?
  date            DateTime
  isRecurring     Boolean        @default(false) @map("isRecurring")
  recurringRuleId String?        @map("recurringRuleId")
  isDeleted       Boolean        @default(false) @map("isDeleted")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  account         Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category        Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@index([recurringRuleId])
  @@map("transactions")
}

/// BudgetEnvelope - Envelope budgeting per category per month
model BudgetEnvelope {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenantId")
  categoryId String   @map("categoryId")
  accountId  String   @map("accountId")
  month      DateTime // First day of the month
  allocated  Decimal  @db.Decimal(15, 2)
  spent      Decimal  @default(0) @db.Decimal(15, 2)
  rolledOver Decimal  @default(0) @db.Decimal(15, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, categoryId, accountId, month])
  @@index([tenantId])
  @@index([categoryId])
  @@index([accountId])
  @@index([month])
  @@map("budget_envelopes")
}

/// RecurringRule - Recurring transaction templates
model RecurringRule {
  id           String        @id @default(cuid())
  tenantId     String        @map("tenantId")
  accountId    String        @map("accountId")
  categoryId   String?       @map("categoryId")
  amount       Decimal       @db.Decimal(15, 2)
  type         String // "income" or "expense"
  payee        String?
  description  String?
  frequency    String // "daily", "weekly", "monthly", "yearly"
  interval     Int           @default(1) // Every N frequency units
  dayOfMonth   Int?          @map("dayOfMonth") // For monthly/yearly
  dayOfWeek    Int?          @map("dayOfWeek") // For weekly (0=Sunday)
  monthOfYear  Int?          @map("monthOfYear") // For yearly (1-12)
  startDate    DateTime      @map("startDate")
  endDate      DateTime?     @map("endDate")
  nextRunAt    DateTime?     @map("nextRunAt")
  lastRunAt    DateTime?     @map("lastRunAt")
  isActive     Boolean       @default(true) @map("isActive")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([tenantId])
  @@index([accountId])
  @@index([nextRunAt])
  @@index([isActive])
  @@map("recurring_rules")
}

/// Task - Tasks with subtask support
model Task {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenantId")
  parentId    String?   @map("parentId")
  parent      Task?     @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Task[]    @relation("TaskHierarchy")
  title       String
  description String?
  dueDate     DateTime? @map("dueDate")
  priority    Int       @default(2) // 1=low, 2=medium, 3=high, 4=urgent
  tags        String[] // Array of tag strings
  isCompleted Boolean   @default(false) @map("isCompleted")
  completedAt DateTime? @map("completedAt")
  isDeleted   Boolean   @default(false) @map("isDeleted")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([parentId])
  @@index([dueDate])
  @@index([isCompleted])
  @@index([priority])
  @@map("tasks")
}

/// Habit - User habits for tracking
model Habit {
  id             String            @id @default(cuid())
  tenantId       String            @map("tenantId")
  name           String            @db.VarChar(100)
  description    String?           @db.VarChar(500)
  frequency      String // "daily", "weekly", "custom"
  cronExpression String?           @map("cronExpression") // For custom schedules like "0 9 * * 1,3,5"
  color          String? // Hex color code
  icon           String? // Emoji or icon name
  isActive       Boolean           @default(true) @map("isActive")
  currentStreak  Int               @default(0) @map("currentStreak")
  longestStreak  Int               @default(0) @map("longestStreak")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  completions    HabitCompletion[]

  @@index([tenantId])
  @@index([isActive])
  @@map("habits")
}

/// HabitCompletion - Daily check-ins for habits
model HabitCompletion {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenantId")
  habitId   String   @map("habitId")
  date      DateTime // Date only - no time component
  completed Boolean  @default(true)
  notes     String?  @db.VarChar(200)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, habitId, date]) // Prevent duplicate check-ins
  @@index([tenantId])
  @@index([habitId])
  @@index([date])
  @@map("habit_completions")
}

/// UserStats - Gamification stats per tenant
model UserStats {
  id              String        @id @default(cuid())
  tenantId        String        @unique @map("tenantId")
  totalXP         Int           @default(0) @map("totalXP")
  currentLevel    Int           @default(1) @map("currentLevel")
  habitsCompleted Int           @default(0) @map("habitsCompleted")
  longestStreak   Int           @default(0) @map("longestStreak")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  achievements    Achievement[]

  @@index([tenantId])
  @@map("user_stats")
}

/// Achievement - Unlocked achievements for gamification
model Achievement {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenantId")
  userStatsId String    @map("userStatsId")
  type        String // "STREAK_7", "STREAK_30", "STREAK_100", "LEVEL_5", etc.
  name        String
  description String
  icon        String?
  unlockedAt  DateTime  @default(now()) @map("unlockedAt")
  habitId     String?   @map("habitId") // For streak achievements
  userStats   UserStats @relation(fields: [userStatsId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, habitId])
  @@index([tenantId])
  @@index([userStatsId])
  @@map("achievements")
}

/// HealthLog - Health tracking entries with flexible JSONB data
model HealthLog {
  id        String        @id @default(cuid())
  tenantId  String        @map("tenantId")
  type      HealthLogType
  loggedAt  DateTime      @map("loggedAt") @db.Timestamp
  data      Json
  notes     String?       @db.VarChar(1000)
  source    String        @default("manual") @db.VarChar(50)
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, loggedAt])
  @@index([tenantId, loggedAt])
  @@map("health_logs")
}

/// Hobby - User hobbies for flexible tracking
model Hobby {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenantId")
  name         String            @db.VarChar(100)
  description  String?           @db.VarChar(500)
  trackingType HobbyTrackingType @map("trackingType")
  goalTarget   Decimal?          @map("goalTarget") @db.Decimal(10, 2)
  goalDeadline DateTime?         @map("goalDeadline")
  isActive     Boolean           @default(true) @map("isActive")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs         HobbyLog[]

  @@index([tenantId])
  @@index([isActive])
  @@map("hobbies")
}

/// HobbyLog - Progress entries for hobbies with flexible JSONB data
model HobbyLog {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenantId")
  hobbyId      String            @map("hobbyId")
  trackingType HobbyTrackingType
  logValue     Json              @map("logValue")
  loggedAt     DateTime          @map("loggedAt") @db.Timestamp
  notes        String?           @db.VarChar(500)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  hobby        Hobby             @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, hobbyId, loggedAt])
  @@index([trackingType])
  @@map("hobby_logs")
}

/// Folder - Single-level folders for note organization
model Folder {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenantId")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes     Note[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("folders")
}

/// Tag - Tags for flexible note categorization
model Tag {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenantId")
  name      String    @db.VarChar(50)
  createdAt DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  noteTags  NoteTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

/// Note - Rich text notes with Tiptap content
model Note {
  id            String                  @id @default(cuid())
  tenantId      String                  @map("tenantId")
  title         String                  @db.VarChar(200)
  content       Json // Tiptap JSON document (max 100KB enforced in app)
  folderId      String?                 @map("folderId")
  search_vector Unsupported("tsvector") // Full-text search vector
  deletedAt     DateTime?               @map("deletedAt") // Soft delete
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folder        Folder?                 @relation(fields: [folderId], references: [id], onDelete: SetNull)
  noteTags      NoteTag[]

  @@index([tenantId])
  @@index([folderId])
  @@index([deletedAt])
  @@map("notes")
}

/// NoteTag - Junction table for note-tag relationships
model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@map("note_tags")
}

/// JournalEntry - Daily journal entries with mood tracking
model JournalEntry {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenantId")
  entryDate DateTime @map("entryDate") @db.Date // Date only
  content   Json // Tiptap JSON document
  mood      Int // 1-5 scale: 1=terrible, 2=bad, 3=neutral, 4=good, 5=excellent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entryDate]) // One entry per day per tenant
  @@index([tenantId])
  @@index([entryDate])
  @@map("journal_entries")
}
